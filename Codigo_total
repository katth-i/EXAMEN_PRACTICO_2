void menuDepuracion() {
    cout << "\n========================================\n";
    cout << "  FRAGMENTO DEFECTUOSO Y SU CORRECCION\n";
    cout << "========================================\n";
    cout << "  CODIGO ORIGINAL CON ERRORES:\n\n";
    cout << "  double calcularPago(double costo, double cobertura){\n";
    cout << "    double pago = costo - cobertura;\n";
    cout << "    if(cobertura > 1)          // ERROR 1\n";
    cout << "      pago = costo * cobertura; // ERROR 2\n";
    cout << "    if(pago < 0) pago = costo;  // ERROR 3\n";
    cout << "    return pago;\n";
    cout << "  }\n\n";
    cout << "  ERRORES IDENTIFICADOS:\n";
    cout << "  ERROR 1: if(cobertura > 1) no tiene sentido logico.\n";
    cout << "    La cobertura en este sistema es un MONTO en dolares,\n";
    cout << "    no un porcentaje entre 0 y 1. La condicion nunca\n";
    cout << "    deberia multiplicar costo * cobertura.\n";
    cout << "  ERROR 2: pago = costo * cobertura produciria un valor\n";
    cout << "    incorrecto (ej: costo=100, cobertura=80 -> pago=8000).\n";
    cout << "  ERROR 3: if(pago < 0) pago = costo; es incorrecto.\n";
    cout << "    Si la cobertura cubre todo el costo, el pago deberia\n";
    cout << "    ser 0, no devolver el costo completo al paciente.\n\n";
    cout << "  CODIGO CORREGIDO:\n\n";
    cout << "  double calcularPago(double costo, double cobertura){\n";
    cout << "    double pago = costo - cobertura;\n";
    cout << "    if(pago < 0) pago = 0; // Correcto: paciente paga $0\n";
    cout << "    return pago;\n";
    cout << "  }\n\n";
    cout << "  PRUEBA MINIMA:\n";
    double c1 = 100.0, cob1 = 80.0;
    double c2 = 50.0,  cob2 = 60.0;
    cout << "  Caso 1: costo=100, cobertura=80 -> pago=" << calcularPago(c1, cob1) << " (esperado: 20)\n";
    cout << "  Caso 2: costo=50,  cobertura=60 -> pago=" << calcularPago(c2, cob2) << " (esperado: 0, cobertura total)\n";
    cout << "========================================\n";
}

