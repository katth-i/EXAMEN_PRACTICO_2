#include <iostream>
#include <string>
#include <vector>
#include <algorithm>
#include <sstream>

using namespace std;


const int MAX_INTENTOS = 6;
const double IVA = 0.15;

class Paciente {
private:
    string cedula;
    string nombre;
    int edad;
    char sexo;
    string tipoSeguro;
    bool riesgo;

public:

    Paciente(string ced, string nom, int ed, char sex, string seg, bool ries)
        : cedula(ced), nombre(nom), edad(ed), sexo(sex), tipoSeguro(seg), riesgo(ries) {}


    string getCedula()    const { return cedula; }
    string getNombre()    const { return nombre; }
    int    getEdad()      const { return edad; }
    char   getSexo()      const { return sexo; }
    string getTipoSeguro()const { return tipoSeguro; }
    bool   getRiesgo()    const { return riesgo; }


    void setNombre(string n)     { nombre = n; }
    void setTipoSeguro(string s) { tipoSeguro = s; }
    void setRiesgo(bool r)       { riesgo = r; }

    void mostrar() const {
        cout << "  Cedula   : " << cedula << "\n"
             << "  Nombre   : " << nombre << "\n"
             << "  Edad     : " << edad << "\n"
             << "  Sexo     : " << sexo << "\n"
             << "  Seguro   : " << tipoSeguro << "\n"
             << "  Riesgo   : " << (riesgo ? "SI" : "NO") << "\n";
    }
};


class Atencion {
private:
    string cedulaPaciente;
    string especialidad;
    int prioridad;
    double costoBase;
    bool tieneExamenes;
    int tiempoEspera;
    string estado;

public:
    // Constructor
    Atencion(string ced, string esp, int pri, double costo, bool exams, int tiempo)
        : cedulaPaciente(ced), especialidad(esp), prioridad(pri),
          costoBase(costo), tieneExamenes(exams), tiempoEspera(tiempo), estado("Pendiente") {}


    string getCedula()       const { return cedulaPaciente; }
    string getEspecialidad() const { return especialidad; }
    int    getPrioridad()    const { return prioridad; }
    double getCostoBase()    const { return costoBase; }
    bool   getExamenes()     const { return tieneExamenes; }
    int    getTiempoEspera() const { return tiempoEspera; }
    string getEstado()       const { return estado; }


    void setEstado(string e)      { estado = e; }
    void setPrioridad(int p)      { prioridad = p; }
    void setCostoBase(double c)   { costoBase = c; }

    void mostrar() const {
        cout << "  Paciente    : " << cedulaPaciente << "\n"
             << "  Especialidad: " << especialidad << "\n"
             << "  Prioridad   : " << prioridad << " (1=Urgente, 2=Moderado, 3=Normal)\n"
             << "  Costo base  : $" << costoBase << "\n"
             << "  Examenes    : " << (tieneExamenes ? "SI" : "NO") << "\n"
             << "  T.Espera    : " << tiempoEspera << " min\n"
             << "  Estado      : " << estado << "\n";
    }
};


bool validarCedula(const string& ced) {
    if (ced.size() != 10) return false;
    for (char c : ced)
        if (c < '0' || c > '9') return false;
    return true;
}


int leerEnteroRango(const string& msg, int minVal, int maxVal) {
    int val;
    do {
        cout << msg;
        while (!(cin >> val)) {
            cin.clear();
            cin.ignore(1000, '\n');
            cout << "  [!] Ingresa un numero entero: ";
        }
        if (val < minVal || val > maxVal)
            cout << "  [!] Debe estar entre " << minVal << " y " << maxVal << ". Intenta de nuevo.\n";
    } while (val < minVal || val > maxVal);
    return val;
}


double leerDoublePositivo(const string& msg) {
    double val;
    do {
        cout << msg;
        while (!(cin >> val)) {
            cin.clear();
            cin.ignore(1000, '\n');
            cout << "  [!] Ingresa un numero valido: ";
        }
        if (val <= 0)
            cout << "  [!] Debe ser mayor que 0.\n";
    } while (val <= 0);
    return val;
}


double totalAtencionesPaciente(const vector<Atencion>& atenciones, const string& cedula, int idx) {
    if (idx >= (int)atenciones.size()) return 0.0;
    double suma = 0.0;
    if (atenciones[idx].getCedula() == cedula)
        suma = atenciones[idx].getCostoBase();
    return suma + totalAtencionesPaciente(atenciones, cedula, idx + 1);
}


double calcularCobertura(const string& tipoSeguro, double costoBase) {
    if (tipoSeguro == "IESS")    return costoBase * 0.80;
    if (tipoSeguro == "Privado") return costoBase * 0.60;
    return 0.0;
}


double calcularPago(double costo, double cobertura) {
    double pago = costo - cobertura;
    if (pago < 0) pago = 0;
    return pago;
}


double calcularRecargo(bool tieneExamenes, double costoBase) {
    if (tieneExamenes) return costoBase * 0.20;
    return 0.0;
}


double calcularRecargoRiesgo(bool riesgo, double costoBase) {
    if (riesgo) return costoBase * 0.10;
    return 0.0;
}


void ordenarPorPrioridad(vector<Atencion>& atenciones) {
    int n = atenciones.size();
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (atenciones[j].getPrioridad() > atenciones[j+1].getPrioridad()) {
                Atencion temp = atenciones[j];
                atenciones[j] = atenciones[j+1];
                atenciones[j+1] = temp;
            }
        }
    }
    cout << "  [OK] Atenciones ordenadas por prioridad (1=Urgente primero).\n";
}


void ordenarPorTiempoEspera(vector<Atencion>& atenciones) {
    int n = atenciones.size();
    for (int i = 0; i < n - 1; i++) {
        for (int j = 0; j < n - i - 1; j++) {
            if (atenciones[j].getTiempoEspera() > atenciones[j+1].getTiempoEspera()) {
                Atencion temp = atenciones[j];
                atenciones[j] = atenciones[j+1];
                atenciones[j+1] = temp;
            }
        }
    }
    cout << "  [OK] Atenciones ordenadas por tiempo de espera.\n";
}


int buscarPacientePorCedula(const vector<Paciente>& pacientes, const string& cedula) {
    for (int i = 0; i < (int)pacientes.size(); i++)
        if (pacientes[i].getCedula() == cedula) return i;
    return -1;
}


vector<int> buscarPorEspecialidad(const vector<Atencion>& atenciones, const string& esp) {
    vector<int> indices;
    for (int i = 0; i < (int)atenciones.size(); i++) {
        string a = atenciones[i].getEspecialidad();
        string b = esp;

        for (char& c : a) c = toupper(c);
        for (char& c : b) c = toupper(c);
        if (a == b) indices.push_back(i);
    }
    return indices;
}


void emitirFactura(const Paciente& p, const vector<Atencion>& atenciones) {
    cout << "\n========================================\n";
    cout << "          FACTURA CLINICA\n";
    cout << "========================================\n";
    p.mostrar();
    cout << "\n  DETALLE DE ATENCIONES:\n";
    cout << "  ----------------------\n";

    double totalGeneral = 0.0;
    int cont = 0;

    for (const Atencion& a : atenciones) {
        if (a.getCedula() == p.getCedula()) {
            cont++;
            double costo      = a.getCostoBase();
            double cobertura  = calcularCobertura(p.getTipoSeguro(), costo);
            double recargo    = calcularRecargo(a.getExamenes(), costo);
            double recRiesgo  = calcularRecargoRiesgo(p.getRiesgo(), costo);
            double subtotal   = calcularPago(costo + recargo + recRiesgo, cobertura);

            cout << "  Atencion #" << cont << "\n";
            cout << "    Especialidad   : " << a.getEspecialidad() << "\n";
            cout << "    Costo base     : $" << costo << "\n";
            cout << "    Recargo examen : $" << recargo << "\n";
            cout << "    Recargo riesgo : $" << recRiesgo << "\n";
            cout << "    Cobertura seg. : $" << cobertura << "\n";
            cout << "    Subtotal       : $" << subtotal << "\n";
            cout << "    ----\n";
            totalGeneral += subtotal;
        }
    }

    if (cont == 0) {
        cout << "  No hay atenciones registradas para este paciente.\n";
        return;
    }

    double iva    = totalGeneral * IVA;
    double total  = totalGeneral + iva;
    cout << "  ----------------------\n";
    cout << "  Subtotal general : $" << totalGeneral << "\n";
    cout << "  IVA (15%)        : $" << iva << "\n";
    cout << "  TOTAL A PAGAR    : $" << total << "\n";
    cout << "========================================\n";
}


void detectarInconsistencias(const vector<Atencion>& atenciones) {
    cout << "\n  ===== INCONSISTENCIAS EN ATENCIONES CRITICAS =====\n";
    bool hayProblemas = false;
    for (const Atencion& a : atenciones) {
        bool problema = false;
        string motivo = "";

        if (a.getPrioridad() == 1 && a.getTiempoEspera() > 30) {
            problema = true;
            motivo = "Paciente URGENTE con espera > 30 min";
        }
        if (a.getCostoBase() < 5.0) {
            problema = true;
            motivo += " | Costo base demasiado bajo ($" + to_string(a.getCostoBase()) + ")";
        }
        if (problema) {
            hayProblemas = true;
            cout << "  [ALERTA] Cedula: " << a.getCedula()
                 << " | Especialidad: " << a.getEspecialidad()
                 << " | " << motivo << "\n";
        }
    }
    if (!hayProblemas)
        cout << "  No se detectaron inconsistencias.\n";
}

void menuRegistroPaciente(vector<Paciente>& pacientes) {
    cout << "\n  === REGISTRAR PACIENTE ===\n";

    string ced;
    do {
        cout << "  Cedula (10 digitos): "; cin >> ced;
        if (!validarCedula(ced))
            cout << "  [!] Cedula invalida. Debe tener 10 digitos numericos.\n";
    } while (!validarCedula(ced));

    if (buscarPacientePorCedula(pacientes, ced) != -1) {
        cout << "  [!] Ya existe un paciente con esa cedula.\n";
        return;
    }

    string nom;
    cout << "  Nombre completo: "; cin.ignore(); getline(cin, nom);

    int edad = leerEnteroRango("  Edad (1-120): ", 1, 120);

    char sexo;
    do {
        cout << "  Sexo (M/F): "; cin >> sexo;
        sexo = toupper(sexo);
        if (sexo != 'M' && sexo != 'F')
            cout << "  [!] Solo M o F.\n";
    } while (sexo != 'M' && sexo != 'F');

    int opSeg;
    cout << "  Tipo de seguro:\n";
    cout << "    1. IESS\n    2. Privado\n    3. Ninguno\n";
    opSeg = leerEnteroRango("  Opcion: ", 1, 3);
    string seguro = (opSeg == 1) ? "IESS" : (opSeg == 2) ? "Privado" : "Ninguno";

    int opRies;
    cout << "  Antecedente de riesgo (1=SI, 2=NO): ";
    opRies = leerEnteroRango("  Opcion: ", 1, 2);
    bool riesgo = (opRies == 1);

    pacientes.emplace_back(ced, nom, edad, sexo, seguro, riesgo);
    cout << "  [OK] Paciente registrado exitosamente.\n";
}

void menuRegistroAtencion(vector<Atencion>& atenciones, const vector<Paciente>& pacientes) {
    cout << "\n  === REGISTRAR ATENCION ===\n";

    string ced;
    cout << "  Cedula del paciente: "; cin >> ced;
    if (buscarPacientePorCedula(pacientes, ced) == -1) {
        cout << "  [!] Paciente no encontrado. Registrelo primero.\n";
        return;
    }

    string esp;
    cout << "  Especialidad (Ej: Cardiologia, Traumatologia): "; cin.ignore(); getline(cin, esp);

    int pri = leerEnteroRango("  Prioridad (1=Urgente, 2=Moderado, 3=Normal): ", 1, 3);
    double costo = leerDoublePositivo("  Costo base ($): ");

    int opEx;
    cout << "  Requiere examenes (1=SI, 2=NO): ";
    opEx = leerEnteroRango("  Opcion: ", 1, 2);
    bool examenes = (opEx == 1);

    int tiempo = leerEnteroRango("  Tiempo de espera (minutos, 0-480): ", 0, 480);

    atenciones.emplace_back(ced, esp, pri, costo, examenes, tiempo);
    cout << "  [OK] Atencion registrada exitosamente.\n";
}

void menuBusquedas(const vector<Paciente>& pacientes, const vector<Atencion>& atenciones) {
    int op;
    cout << "\n  === BUSQUEDAS ===\n";
    cout << "  1. Buscar paciente por cedula\n";
    cout << "  2. Buscar atenciones por especialidad\n";
    op = leerEnteroRango("  Opcion: ", 1, 2);

    if (op == 1) {
        string ced;
        cout << "  Cedula: "; cin >> ced;
        int idx = buscarPacientePorCedula(pacientes, ced);
        if (idx == -1) { cout << "  [!] No encontrado.\n"; return; }
        pacientes[idx].mostrar();

        cout << "\n  Atenciones del paciente:\n";
        for (const Atencion& a : atenciones)
            if (a.getCedula() == ced) a.mostrar();
    } else {
        string esp;
        cout << "  Especialidad: "; cin.ignore(); getline(cin, esp);
        vector<int> resultados = buscarPorEspecialidad(atenciones, esp);
        if (resultados.empty()) { cout << "  [!] No se encontraron atenciones.\n"; return; }
        for (int i : resultados) atenciones[i].mostrar();
    }
}

void menuReportes(const vector<Paciente>& pacientes, const vector<Atencion>& atenciones) {
    int op;
    cout << "\n  === REPORTES ===\n";
    cout << "  1. Listar todos los pacientes\n";
    cout << "  2. Listar todas las atenciones\n";
    cout << "  3. Total cobros por paciente (recursivo)\n";
    cout << "  4. Detectar inconsistencias\n";
    op = leerEnteroRango("  Opcion: ", 1, 4);

    if (op == 1) {
        if (pacientes.empty()) { cout << "  No hay pacientes.\n"; return; }
        for (int i = 0; i < (int)pacientes.size(); i++) {
            cout << "\n  --- Paciente " << (i+1) << " ---\n";
            pacientes[i].mostrar();
        }
    } else if (op == 2) {
        if (atenciones.empty()) { cout << "  No hay atenciones.\n"; return; }
        for (int i = 0; i < (int)atenciones.size(); i++) {
            cout << "\n  --- Atencion " << (i+1) << " ---\n";
            atenciones[i].mostrar();
        }
    } else if (op == 3) {
        string ced;
        cout << "  Cedula del paciente: "; cin >> ced;
        double total = totalAtencionesPaciente(atenciones, ced, 0);
        cout << "  Total de costos base para cedula " << ced << ": $" << total << "\n";
        cout << "  (Calculado con funcion recursiva)\n";
    } else {
        detectarInconsistencias(atenciones);
    }
}

void menuOrdenamiento(vector<Atencion>& atenciones) {
    int op;
    cout << "\n  === ORDENAMIENTO MANUAL ===\n";
    cout << "  1. Ordenar por prioridad\n";
    cout << "  2. Ordenar por tiempo de espera\n";
    op = leerEnteroRango("  Opcion: ", 1, 2);
    if (op == 1) ordenarPorPrioridad(atenciones);
    else         ordenarPorTiempoEspera(atenciones);
}

void menuFactura(const vector<Paciente>& pacientes, const vector<Atencion>& atenciones) {
    string ced;
    cout << "\n  Cedula del paciente para factura: "; cin >> ced;
    int idx = buscarPacientePorCedula(pacientes, ced);
    if (idx == -1) { cout << "  [!] Paciente no encontrado.\n"; return; }
    emitirFactura(pacientes[idx], atenciones);
}
